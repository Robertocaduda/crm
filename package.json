{
  "name": "crm",
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "turbo run db:migrate --filter=@crm/db",
    "db:seed": "turbo run db:seed --filter=@crm/db"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
